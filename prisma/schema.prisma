// EarlyBird — Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: the connection URL lives in prisma.config.ts (migrations) and is
  // supplied to PrismaClient at runtime via a driver adapter (see src/lib/prisma.ts).
}

// Broad job family, inferred from the listing title during normalization.
enum Category {
  SWE
  ML_AI
  DATA
  QUANT
  HARDWARE
  PM
  OTHER
}

// Where a notification is delivered.
enum Channel {
  EMAIL
  DISCORD
  TELEGRAM
}

// How often a user is alerted.
enum Frequency {
  INSTANT
  DAILY_DIGEST
}

// A single internship posting, normalized across all sources.
model Listing {
  // Stable hash of source + company + title + url (see lib/ingest/hash.ts).
  id          String    @id
  source      String // which repo this row came from (e.g. "vanshb03")
  company     String
  title       String
  category    Category  @default(OTHER)
  locations   String[] // may be empty if the source omits it
  applyUrl    String
  sponsorship String? // free-text from the source, nullable
  season      String? // e.g. "Summer", "Winter"
  datePosted  DateTime? // from the source's date_posted (nullable)

  // firstSeenAt: when OUR system first ingested this row. Set once, never updated.
  firstSeenAt DateTime @default(now())
  // lastSeenAt: refreshed on every ingest run the row appears in.
  lastSeenAt  DateTime @default(now())
  active      Boolean  @default(true)

  // effectiveAt: the materialized "how new is this" timestamp used for sorting
  // and recency windows. = datePosted when present & sane, else firstSeenAt.
  // Computed at ingest time so feed queries stay a simple, indexed sort.
  effectiveAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentNotifications SentNotification[]

  // Hot paths: newest-first queries and recency-window filters.
  @@index([effectiveAt])
  @@index([firstSeenAt])
  @@index([active])
  @@index([category])
}

// How a hackathon runs — online, physically, or both.
enum HackathonFormat {
  ONLINE
  IN_PERSON
  HYBRID
}

// A single hackathon, normalized across sources (MLH, Devpost).
model Hackathon {
  // Stable hash of name + url host/path (see lib/ingest/hackathons/hash.ts).
  id     String @id
  source String // "mlh" | "devpost" (may be merged, e.g. "mlh+devpost")
  name   String
  url    String // the event's own registration/site link

  format        HackathonFormat @default(IN_PERSON)
  locationLabel String          @default("") // "Online" or "New York, NY"
  country       String? // ISO-ish country of an in-person venue; null when online/unknown

  startsAt  DateTime? // event start (nullable when a source omits it)
  endsAt    DateTime?
  dateLabel String? // human range straight from the source ("May 19 - Aug 17, 2026")

  prize        String? // prize-pool text (Devpost), free-form
  themes       String[] // themes / tags
  participants Int? // registrations count when the source exposes it
  imageUrl     String?

  // firstSeenAt: when OUR system first ingested this event. Set once.
  firstSeenAt DateTime @default(now())
  // lastSeenAt: refreshed every ingest run the event still appears in.
  lastSeenAt  DateTime @default(now())
  active      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hot paths: soonest-first ordering, recency of discovery, and format filter.
  @@index([startsAt])
  @@index([firstSeenAt])
  @@index([active])
  @@index([format])
}

// Application lifecycle stage, detected from email (see lib/apptracker).
enum AppStage {
  APPLIED
  ASSESSMENT
  INTERVIEW
  OFFER
  REJECTED
}

// A single job application the user is tracking, populated automatically from
// their forwarded/labeled email (or added manually). Anonymous + per-user via a
// secret ownerKey (no accounts) — same private-by-key model as the feed's
// localStorage tracking, but server-side so an email job can write to it.
model TrackedApplication {
  id       String   @id @default(cuid())
  ownerKey String // the user's secret tracker key
  company  String
  role     String   @default("") // "" when the email didn't name a role
  stage    AppStage @default(APPLIED)

  // eventDate: date of the current stage's email (the "applied on / rejected on"
  // date). appliedAt: earliest date we ever saw this application.
  eventDate DateTime
  appliedAt DateTime?

  source      String  @default("email") // "email" | "manual"
  lastSubject String? // subject of the most recent email, for context

  // Soft delete: set when the user removes it, so it can be restored from Trash.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emails ApplicationEmail[]

  // One row per (owner, company, role); repeat emails update it in place.
  @@unique([ownerKey, company, role])
  @@index([ownerKey])
}

// The full text of every email that fed a tracked application, so the UI can
// show the complete message history for each one. Populated at ingest time
// (older applications predate this and won't have stored bodies).
model ApplicationEmail {
  id            String   @id @default(cuid())
  applicationId String
  ownerKey      String
  subject       String
  body          String // full plain-text body
  fromAddr      String?
  stage         AppStage // stage this email was classified as
  eventDate     DateTime // the email's event date (parsed/forwarded)
  msgHash       String // sha256(subject|body|eventDate) — dedupes re-ingests
  createdAt     DateTime @default(now())

  application TrackedApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([ownerKey, msgHash])
}

// One row per page view, for the private /stats page. Privacy-first: we store
// NO IP or user-agent — only `visitorDay`, a salted daily hash of them, so we
// can count same-day unique visitors without being able to identify or track
// anyone across days.
model PageView {
  id         String   @id @default(cuid())
  path       String
  day        String // "YYYY-MM-DD" (UTC), for cheap daily grouping
  visitorDay String // sha256(salt | ip | ua | day) — daily-unique, not personal
  createdAt  DateTime @default(now())

  @@index([day])
  @@index([createdAt])
}

// A user account. Populated by Google sign-in (Auth.js). trackerKey ties the
// email application-tracker (and the Gmail Apps Script's posts) to the account,
// so signing in on any browser reloads the user's data — no key to lose.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  trackerKey    String?   @unique // application-tracker key; also used by the Gmail script
  createdAt     DateTime  @default(now())

  accounts          Account[]
  sessions          Session[]
  preferences       NotificationPreference[]
  sentNotifications SentNotification[]
}

// Auth.js: a linked OAuth account (Google) for a User.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Auth.js: a login session (database strategy).
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Auth.js: email verification tokens (unused with Google-only, but the adapter
// expects the model to exist).
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// A user's alert rule. A user may have several (e.g. instant email + daily Discord digest).
model NotificationPreference {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories         String[] // Category names to alert on; empty = all categories
  keywords           String[] // optional title keyword filters (case-insensitive)
  locationsFilter    String[] // optional location substrings
  activeOnly         Boolean   @default(true)
  channel            Channel
  channelTarget      String // email address, webhook URL, or "botToken|chatId" (Telegram)
  frequency          Frequency @default(INSTANT)
  recencyWindowHours Int       @default(48)

  // Daily-digest scheduling. digestHour is the local-to-UTC hour (0-23) the
  // digest should go out; lastDigestAt records when we last sent one so we send
  // at most once per day even if /api/notify is hit several times that hour.
  digestHour   Int       @default(8)
  lastDigestAt DateTime?

  enabled Boolean @default(true) // soft on/off switch for the rule

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Ledger ensuring a listing is never alerted to the same user twice.
model SentNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sentAt    DateTime @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
}
