# EarlyBird environment variables — copy to .env and fill in real values.

# --- Database ---
# Any Postgres connection string. For Neon/Supabase, keep `?sslmode=require`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Notifications (Phase 4) ---
# Resend API key for email notifications: https://resend.com
RESEND_API_KEY=
# Verified sender. Use "onboarding@resend.dev" for quick testing.
RESEND_FROM="EarlyBird <onboarding@resend.dev>"
# Public base URL of the deployment, used to build links in notification emails.
APP_URL="http://localhost:3000"

# --- Cron / ingest protection (Phase 5) ---
# Shared secret guarding /api/ingest and /api/notify. When set, requests must
# present it as `Authorization: Bearer <secret>` (Vercel Cron sends this header
# automatically), or as an `x-cron-secret` header, or a `?secret=` query param.
# Leave blank in local dev to allow unauthenticated manual triggering.
CRON_SECRET=
